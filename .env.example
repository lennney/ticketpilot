# TicketPilot Environment Configuration
# Copy this file to .env.local and fill in your values
# See also: .env.example for reference

# =====================
# Database Configuration
# =====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ticketpilot
DB_USER=ticketpilot
DB_PASSWORD=your_password_here

# =====================
# Embedding Provider (DashScope)
# =====================
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# =====================
# CORS Configuration (comma-separated origins)
# =====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =====================
# LLM Provider (DeepSeek)
# =====================
TICKETPILOT_LLM_PROVIDER=openai_compatible
TICKETPILOT_LLM_BASE_URL=https://api.deepseek.com
TICKETPILOT_LLM_API_KEY=your_deepseek_api_key_here
TICKETPILOT_LLM_MODEL=deepseek-chat
TICKETPILOT_LLM_TIMEOUT_SECONDS=60
TICKETPILOT_LLM_MAX_TOKENS=1024
TICKETPILOT_LLM_TEMPERATURE=0.3
