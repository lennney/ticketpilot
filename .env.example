# Database (PostgreSQL + pgvector)
# Used by src/ticketpilot/retrieval/db/connection.py
# Default values match docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ticketpilot
DB_USER=ticketpilot
DB_PASSWORD=ticketpilot

# Connection URL (alternative to individual DB_* vars)
DATABASE_URL=postgresql+psycopg://ticketpilot:ticketpilot@localhost:5432/ticketpilot

# Embedding Provider Configuration (Phase 8)
# "fake" = deterministic 384-dim SHA-256 based vectors for pipeline verification (default)
# "openai_compatible" = real embedding via OpenAI-compatible API (opt-in, requires API key)
EMBEDDING_PROVIDER=fake
# Model name for real embedding provider (ignored when provider=fake)
EMBEDDING_MODEL=fake-384
# Expected embedding vector dimension (must match provider output)
EMBEDDING_DIM=384
# API base URL for openai_compatible provider (optional, default: https://api.openai.com/v1)
EMBEDDING_BASE_URL=
# Batch size for batch embedding (default: 32)
EMBEDDING_BATCH_SIZE=32
# EMBEDDING_API_KEY must be set only in local environment or .env.local
# Do not commit real API keys to the repository.
# EMBEDDING_API_KEY=

# LLM Provider (unused in current MVP — templates only)
# LLM_PROVIDER=fake
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=fake-model

# Review console output path (default: data/review/)
# REVIEW_STORE_PATH=data/review

# Evaluation report output path (default: reports/eval/)
# EVAL_REPORT_DIR=reports/eval
